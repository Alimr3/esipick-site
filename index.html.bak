<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Esipick.tech — n8n Automation & AI Video</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --pink:#FF3CAC;--purple:#784BA0;--cyan:#2BD9D9;
  --bg:#F5F5F3;--surface:#FFFFFF;--surface-2:#EFEFEC;
  --border:#E2E2DE;--border-2:#CACAC5;
  --ink:#0A0A0A;--ink-2:#222222;--ink-3:#555555;--ink-4:#939393;
  --g-brand:linear-gradient(135deg,#FF3CAC 0%,#784BA0 50%,#2BD9D9 100%);
  --g-cta:linear-gradient(90deg,#FF3CAC,#2BD9D9);
  --g-pink:linear-gradient(90deg,#FF3CAC,#784BA0);
  --sans:'Space Grotesk','Palatino Linotype',Georgia,serif;
  --mono:'Space Mono',monospace;
  --r:10px;--r-lg:18px;
  --sh:0 1px 2px rgba(0,0,0,.04),0 4px 16px rgba(0,0,0,.055);
  --sh-lg:0 2px 4px rgba(0,0,0,.04),0 16px 48px rgba(0,0,0,.09);
}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--bg);color:var(--ink);font-size:16px;line-height:1.55;overflow-x:hidden;-webkit-font-smoothing:antialiased}
.grad{background:var(--g-brand);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.section{padding:100px 5%}
.inner{max-width:1160px;margin:0 auto}
.ey{display:inline-flex;align-items:center;gap:10px;font-family:var(--mono);font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--ink-4);margin-bottom:20px}
.ey-bar{width:20px;height:1px;background:linear-gradient(90deg,#FF3CAC,#2BD9D9);flex-shrink:0}
.h2{font-family:var(--sans);font-size:clamp(34px,4vw,54px);font-weight:700;line-height:1.1;letter-spacing:-1px;color:var(--ink);margin-bottom:14px}
.h2 em{font-style:normal;background:var(--g-brand);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.sub{font-size:16px;font-weight:400;color:var(--ink-3);line-height:1.7;max-width:480px}
.ico{width:44px;height:44px;border-radius:10px;border:1px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .2s,background .2s,box-shadow .2s}
.ico svg{width:18px;height:18px;stroke:var(--ink-3);stroke-width:1.5;fill:none;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.rev{opacity:0;transform:translateY(20px);transition:opacity .55s ease-out,transform .55s ease-out}
.rev.in{opacity:1;transform:none}
.d1{transition-delay:.07s}.d2{transition-delay:.14s}.d3{transition-delay:.21s}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 5%;background:rgba(245,245,243,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid transparent;transition:border-color .3s,box-shadow .3s}
nav.on{border-color:var(--border);box-shadow:0 1px 20px rgba(0,0,0,.06)}
.logo{font-family:var(--sans);font-size:15.5px;font-weight:700;color:var(--ink);text-decoration:none;letter-spacing:-.3px;display:flex;align-items:center;gap:3px}
.logo-dot{width:6px;height:6px;border-radius:50%;background:linear-gradient(135deg,#FF3CAC,#2BD9D9);margin-left:2px;flex-shrink:0}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none}
.nav-links a{font-size:13px;font-weight:500;color:var(--ink-3);text-decoration:none;transition:color .18s}
.nav-links a:hover{color:var(--ink)}
.nav-cta{background:var(--ink);color:#fff!important;padding:8px 18px;border-radius:7px;font-size:13px!important;font-weight:600!important;transition:opacity .2s!important}
.nav-cta:hover{opacity:.8}
.burger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.burger span{display:block;width:20px;height:1.5px;background:var(--ink);border-radius:2px;transition:.3s}
.burger.open span:nth-child(1){transform:rotate(45deg) translateY(6.5px)}
.burger.open span:nth-child(2){opacity:0}
.burger.open span:nth-child(3){transform:rotate(-45deg) translateY(-6.5px)}
.mob{display:none;position:fixed;inset:0;background:var(--bg);z-index:199;padding:90px 5% 40px;flex-direction:column}
.mob.open{display:flex}
.mob a{font-family:var(--sans);font-size:32px;font-weight:700;color:var(--ink);text-decoration:none;padding:16px 0;border-bottom:1px solid var(--border);transition:color .2s;letter-spacing:-.5px}
.mob a:hover{color:var(--purple)}
.mob a:last-child{border-bottom:none}

/* HERO */
.hero{min-height:100vh;padding:120px 5% 90px;display:flex;align-items:center;position:relative;overflow:hidden;background:var(--bg)}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:radial-gradient(circle,rgba(0,0,0,.09) 1px,transparent 1px);background-size:22px 22px;opacity:.4}
.hero-grid::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 70% at 50% 50%,transparent 20%,var(--bg) 75%)}
.hero-glow{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 50% 50% at 92% 10%,rgba(255,60,172,.07) 0%,transparent 55%),radial-gradient(ellipse 40% 50% at 8% 90%,rgba(43,217,217,.06) 0%,transparent 55%)}
.hero-inner{position:relative;z-index:2;max-width:1160px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
.hero-status{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-4);background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:7px 14px;margin-bottom:28px;opacity:0;animation:up .5s .1s ease-out forwards}
.sdot{width:6px;height:6px;border-radius:50%;background:#22c55e;animation:blink 1.8s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hero-h1{font-family:var(--sans);font-size:clamp(44px,5.8vw,76px);font-weight:700;line-height:1.06;letter-spacing:-2px;color:var(--ink);margin-bottom:20px;opacity:0;animation:up .55s .18s ease-out forwards}
.hero-h1 .accent{display:block;background:var(--g-brand);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-p{font-size:15.5px;color:var(--ink-3);line-height:1.75;max-width:420px;margin-bottom:36px;opacity:0;animation:up .55s .3s ease-out forwards}
.hero-btns{display:flex;gap:10px;flex-wrap:wrap;align-items:center;opacity:0;animation:up .55s .42s ease-out forwards}
.btn-dark{display:inline-flex;align-items:center;gap:7px;padding:13px 26px;border-radius:8px;background:var(--ink);color:#fff;font-family:var(--sans);font-size:13.5px;font-weight:600;text-decoration:none;transition:opacity .2s,transform .2s}
.btn-dark:hover{opacity:.8;transform:translateY(-1px)}
.btn-dark svg{width:13px;height:13px;stroke:#fff;stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}
.btn-ghost{display:inline-flex;align-items:center;gap:7px;padding:12px 20px;border-radius:8px;border:1px solid var(--border-2);background:transparent;color:var(--ink-2);font-family:var(--sans);font-size:13.5px;font-weight:500;text-decoration:none;transition:border-color .2s,background .2s}
.btn-ghost:hover{border-color:var(--ink-3);background:var(--surface-2)}
.btn-ghost svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}
.hero-stats{display:flex;gap:0;margin-top:40px;padding-top:28px;border-top:1px solid var(--border);opacity:0;animation:up .55s .56s ease-out forwards}
.hs{flex:1;padding-right:20px;border-right:1px solid var(--border);margin-right:20px}
.hs:last-child{border-right:none;margin-right:0;padding-right:0}
.hs-val{font-family:var(--sans);font-size:28px;font-weight:700;letter-spacing:-1px;line-height:1;margin-bottom:3px}
.hs-label{font-family:var(--mono);font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-4)}
/* hero right card */
.hero-right{opacity:0;animation:up .65s .48s ease-out forwards}
.dash{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;box-shadow:var(--sh-lg)}
.dash-bar{display:flex;align-items:center;gap:6px;padding:12px 16px;background:var(--surface-2);border-bottom:1px solid var(--border)}
.ddot{width:10px;height:10px;border-radius:50%}
.dash-title{font-family:var(--mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-4);margin:0 auto}
.dash-body{padding:20px}
.pipe-label{font-family:var(--mono);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--ink-4);display:flex;align-items:center;gap:6px;margin-bottom:14px}
.plive{width:5px;height:5px;border-radius:50%;background:#22c55e;animation:blink 1.8s infinite}
.pipeline{display:flex;align-items:center;gap:4px;margin-bottom:20px;overflow:hidden}
.pnode{flex-shrink:0;background:var(--surface-2);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-family:var(--mono);font-size:11px;font-weight:700;color:var(--ink-2);white-space:nowrap}
.pnode.active{border-color:var(--pink);background:rgba(255,60,172,.04)}
.parr{color:var(--border-2);font-size:12px;flex-shrink:0;font-family:var(--mono)}
.metrics{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:var(--border);border-radius:8px;overflow:hidden;margin-bottom:18px}
.metric{background:var(--surface);padding:14px 14px}
.m-val{font-family:var(--sans);font-size:24px;font-weight:700;letter-spacing:-1px;line-height:1;color:var(--ink)}
.m-label{font-family:var(--mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-4);margin-top:3px}
.wf-status{background:var(--surface-2);border:1px solid var(--border);border-radius:8px;padding:14px 16px}
.wf-row{display:flex;align-items:center;gap:10px;padding:5px 0}
.wf-row+.wf-row{border-top:1px solid var(--border)}
.wf-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.wf-name{font-family:var(--mono);font-size:11px;color:var(--ink-2);flex:1}
.wf-badge{font-family:var(--mono);font-size:9px;letter-spacing:.5px;padding:2px 7px;border-radius:3px}
.done{background:rgba(34,197,94,.1);color:#16a34a}
.run{background:rgba(255,60,172,.1);color:var(--pink)}
.wait{background:var(--surface-2);color:var(--ink-4);border:1px solid var(--border)}
@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}

/* TICKER */
.ticker{background:var(--ink);padding:11px 0;overflow:hidden}
.t-track{display:flex;width:max-content;animation:tick 32s linear infinite}
.ti{display:inline-flex;align-items:center;gap:12px;padding:0 32px;font-family:var(--mono);font-size:9.5px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35);white-space:nowrap}
.ti-sep{width:3px;height:3px;border-radius:50%;background:var(--pink);flex-shrink:0;opacity:.7}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* LOGOS */
.logos{padding:48px 5%;background:var(--surface);border-bottom:1px solid var(--border)}
.logos-label{font-family:var(--mono);font-size:9.5px;letter-spacing:2.5px;text-transform:uppercase;color:var(--ink-4);text-align:center;margin-bottom:32px}
.logos-row{display:flex;align-items:center;justify-content:center;gap:44px;flex-wrap:wrap}
.logo-item{display:flex;align-items:center;gap:9px;opacity:.35;filter:grayscale(1);transition:opacity .2s}
.logo-item:hover{opacity:.65}
.logo-icon{width:28px;height:28px;border-radius:6px;background:var(--ink);display:flex;align-items:center;justify-content:center}
.logo-icon svg{width:14px;height:14px;stroke:#fff;stroke-width:1.5;fill:none;stroke-linecap:round;stroke-linejoin:round}
.logo-name{font-family:var(--sans);font-size:13px;font-weight:700;color:var(--ink)}

/* SERVICES */
.svc-bg{background:var(--surface)}
.svc-hd{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:60px}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);background:var(--border);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;gap:1px}
.svc{background:var(--surface);padding:32px 28px;position:relative;transition:background .2s;cursor:default}
.svc:hover{background:var(--bg)}
.svc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--g-brand);opacity:0;transition:opacity .2s}
.svc:hover::before{opacity:1}
.svc:hover .ico{border-color:rgba(120,75,160,.4);background:rgba(120,75,160,.05)}
.svc:hover .ico svg{stroke:var(--purple)}
.svc-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:20px}
.svc-num{font-family:var(--mono);font-size:10px;color:var(--ink-4);padding-top:2px;letter-spacing:1px}
.svc-title{font-family:var(--sans);font-size:15px;font-weight:700;color:var(--ink);margin-bottom:5px;letter-spacing:-.2px}
.svc-tagline{font-family:var(--mono);font-size:9.5px;letter-spacing:1px;text-transform:uppercase;color:var(--purple);margin-bottom:10px}
.svc-desc{font-size:13.5px;color:var(--ink-3);line-height:1.65;margin-bottom:16px}
.svc-stack{font-family:var(--mono);font-size:9.5px;letter-spacing:.8px;color:var(--ink-4)}

/* PROCESS */
.proc-layout{display:grid;grid-template-columns:1fr 1fr;gap:90px;align-items:center}
.proc-steps{margin-top:44px}
.pstep{display:flex;gap:16px;padding:22px 0;border-bottom:1px solid var(--border);transition:padding-left .2s;cursor:default}
.pstep:first-child{border-top:1px solid var(--border)}
.pstep:hover{padding-left:8px}
.pstep:hover .ico{border-color:rgba(255,60,172,.35);background:rgba(255,60,172,.04)}
.pstep:hover .ico svg{stroke:var(--pink)}
.pstep-n{font-family:var(--mono);font-size:10px;color:var(--ink-4);padding-top:13px;flex-shrink:0;width:22px;letter-spacing:1px}
.pstep-title{font-size:15px;font-weight:700;color:var(--ink);margin-bottom:3px;letter-spacing:-.2px}
.pstep-tag{font-family:var(--mono);font-size:9.5px;letter-spacing:1px;text-transform:uppercase;color:var(--purple);margin-bottom:6px}
.pstep-desc{font-size:13.5px;color:var(--ink-3);line-height:1.65}
/* process visual */
.proc-vis{position:relative;height:490px}
.pcard{position:absolute;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);box-shadow:var(--sh)}
.pc-main{top:0;left:0;right:0;padding:20px}
.pc-topbar{display:flex;align-items:center;gap:6px;padding:8px 12px;background:var(--surface-2);border-radius:7px;margin-bottom:14px}
.pc-topbar span{font-family:var(--mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-4);margin-left:6px}
.pc-chain{display:flex;flex-direction:column;gap:6px}
.pc-node{background:var(--surface-2);border:1px solid var(--border);border-radius:7px;padding:9px 12px;display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;font-weight:700;color:var(--ink-2)}
.pc-nd{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.pc-badge{margin-left:auto;font-family:var(--mono);font-size:9px;letter-spacing:.5px;padding:2px 7px;border-radius:3px}
.pc-arr{padding-left:18px;font-family:var(--mono);font-size:11px;color:var(--border-2)}
.pc-video{bottom:0;right:0;width:55%;padding:18px}
.pc-stat{bottom:84px;left:0;width:44%;padding:20px}
.pc-sval{font-family:var(--sans);font-size:38px;font-weight:700;letter-spacing:-2px;line-height:1;margin-bottom:4px}
.pc-slabel{font-family:var(--mono);font-size:9.5px;letter-spacing:1px;text-transform:uppercase;color:var(--ink-3)}
.vid-thumb{width:100%;aspect-ratio:16/9;border-radius:8px;background:linear-gradient(135deg,#0f0f1e,#1a0a2e,#0a1a2e);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.vid-sh{position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,60,172,.18),rgba(120,75,160,.14),rgba(43,217,217,.1));animation:sh 4s ease-in-out infinite alternate}
@keyframes sh{from{opacity:.5}to{opacity:1}}
.vid-play{position:relative;z-index:1;width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.9);display:flex;align-items:center;justify-content:center}
.vid-play svg{width:11px;height:11px;stroke:var(--ink);stroke-width:2;fill:none;margin-left:2px}
.vid-title{font-family:var(--sans);font-size:12.5px;font-weight:600;color:var(--ink)}
.vid-sub{font-family:var(--mono);font-size:9.5px;letter-spacing:.5px;color:var(--ink-4);margin-top:3px}

/* USE CASES */
.uc-bg{background:#0A0A0A}
.uc-hd{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:52px}
.uc-hd .h2{color:#fff}
.uc-hd .ey{color:rgba(255,255,255,.3)}
.uc-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.07);border-radius:var(--r-lg);overflow:hidden}
.uc{background:rgba(255,255,255,.025);padding:36px 32px;position:relative;overflow:hidden;transition:background .2s;cursor:default}
.uc:hover{background:rgba(255,255,255,.045)}
.uc::before{content:'';position:absolute;top:0;left:0;right:0;height:1.5px;background:var(--g-brand);opacity:0;transition:opacity .2s}
.uc:hover::before{opacity:1}
.uc.wide{grid-column:span 2;display:grid;grid-template-columns:1fr 1fr;gap:56px}
.uc-num{font-family:var(--mono);font-size:9.5px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.2);margin-bottom:16px}
.uc-title{font-family:var(--sans);font-size:21px;font-weight:700;color:#fff;margin-bottom:5px;letter-spacing:-.3px;line-height:1.2}
.uc-tagline{font-family:var(--mono);font-size:9.5px;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,60,172,.7);margin-bottom:12px}
.uc-desc{font-size:13.5px;color:rgba(255,255,255,.42);line-height:1.7;margin-bottom:20px}
.uc-tags{display:flex;gap:6px;flex-wrap:wrap}
.uc-tag{font-family:var(--mono);font-size:9px;letter-spacing:.5px;color:rgba(255,255,255,.28);border:1px solid rgba(255,255,255,.09);padding:4px 9px;border-radius:4px}
.uc-nums{display:flex;flex-direction:column;justify-content:center;gap:16px}
.uc-nb{padding:20px 22px;border-radius:var(--r);border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03)}
.uc-nval{font-family:var(--sans);font-size:40px;font-weight:700;letter-spacing:-2px;line-height:1;margin-bottom:4px}
.uc-nlabel{font-family:var(--mono);font-size:9.5px;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.3)}
</style>
</head>
<body>

<nav id="nav">
  <a href="#" class="logo">esipick<span style="opacity:.35">.</span>tech<span class="logo-dot"></span></a>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#founder">About</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#blog">Insights</a></li>
    <li><a href="#contact" class="nav-cta">Book a Call</a></li>
  </ul>
  <div class="burger" id="burger"><span></span><span></span><span></span></div>
</nav>
<div class="mob" id="mob">
  <a href="#services" onclick="cm()">Services</a>
  <a href="#process" onclick="cm()">Process</a>
  <a href="#founder" onclick="cm()">About</a>
  <a href="#pricing" onclick="cm()">Pricing</a>
  <a href="#blog" onclick="cm()">Insights</a>
  <a href="#contact" onclick="cm()">Book a Call →</a>
</div>

<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div>
      <div class="hero-status"><span class="sdot"></span>System live — 47 workflows running</div>
      <h1 class="hero-h1">Your business,<br><span class="accent">running while<br>you sleep.</span></h1>
      <p class="hero-p">We build n8n automation pipelines and AI video content for companies serious about growth — without growing their headcount. 15 years of technology practice behind every workflow.</p>
      <div class="hero-btns">
        <a href="#contact" class="btn-dark">Book a free strategy call <svg viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg></a>
